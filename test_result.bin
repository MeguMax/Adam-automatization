<body>
    <div class="container-fluid body-content">
        
        

<div class="jumbotron2">
    <img src="/Home/GetLogo" class="tc-logo" alt="Company Logo" />
    <span class="tc-title">TrueCertify</span>

        <div class="tc-container">
            <p class="tc-text">Please enter the information below to access the certified document.</p>
            <hr class="tc-divider" />
            <form action="/" method="post">                <div class="tc-form-row">
                    <div class="tc-field">
                        <p>File Locator</p>
                        <input class="tc-input" id="DocumentLocator" name="DocumentLocator" type="text" value="MIP63-S2HGMQ-FF7DC1F3" />
                    </div>
                    <div class="tc-field">
                        <p>Public Key</p>
                        <input class="tc-input" id="PublicKey" name="PublicKey" type="text" value="3A7" />
                    </div>
                </div>
                <div class="tc-clear"></div>
                    <p class="tc-text tc-mt40">Type in the text from the image below.</p>
                    <div class="tc-captcha">
                        <div class="tc-inline">
                            <input class="tc-captcha-input" id="CaptchaValue" name="CaptchaValue" type="text" value="eNFAy" />
                        </div>
                        <div class="tc-inline tc-image-container">
                            <img src="/Home/GetCaptcha" class="tc-responsive-img" alt="CAPTCHA image" />
                        </div>
                        <br />
                        <div class="tc-inline">
                            <a href="/?loc=MIP63-S2HGMQ-FF7DC1F3&amp;key=3A7&amp;useRecaptcha=True" class="tc-accessibility-link">
                                Switch to accessible captcha
                            </a>
                        </div>
                        <div class="tc-centered">
                            <span class="tc-error"></span>
                        </div>
                    </div>
                <input type="submit" name="action" value="Submit" class="btn btn-primary btn-lg tc-submit" />
                <br />
                <br />
                <span class="tc-error">There was an error processing the request. Please check the file locator, key and expiration date and try again.</span>
                <span class="tc-error"></span>
                <span class="tc-error"></span>
<input id="CaptchaToken" name="CaptchaToken" type="hidden" value="" /><input id="CaptchaValue" name="CaptchaValue" type="hidden" value="eNFAy" /><input id="VersionNumber" name="VersionNumber" type="hidden" value="" /></form>        </div>
    <div class="tc-version"></div>
</div>
        <div class="navbar navbar-inverse navbar-fixed-bottom">
            <div class="container-fluid">
                <div class="navbar-collapse collapse">
                    <ul class="nav navbar-nav">
