                        <li><a href="/Home/FAQ">FAQ</a></li>
                        <li><a href="http://www.truecertify.com" target="_blank">About TrueCertify</a></li>
                    </ul>
                    <span style="float: right; margin-top: 18px; color: silver; font-size: 14px;">&copy; 2026 - ImageSoft Inc.</span>
                </div>
            </div>
        </div>
    </div>
